# ── Proxmox ───────────────────────────────────────────────────────────────
PROXMOX_ROOT_PASSWORD=changeme123
# Format: PVEAPIToken=USER@REALM!TOKENID=UUID
PROXMOX_API_TOKEN=apiuser@pve!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_NODE=pve
PROXMOX_VERIFY_TLS=false

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=vmpdb
POSTGRES_USER=vmp
POSTGRES_PASSWORD=change_this_password

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password

# ── JWT / Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change_this_nextauth_secret
NEXTAUTH_URL=http://localhost

# ── Portal ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api
